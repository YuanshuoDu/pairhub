# =====================================================================
# Pairhub Server — multi-stage Dockerfile
# Target: < 200 MB final image, Node 20 LTS.
#
# Stages:
#   build   — installs all (dev + prod) deps with npm, runs prisma
#             generate + tsc -> dist/. The key trick to keep the
#             runtime image small is `npm ci --omit=dev` in the
#             runtime stage: it produces a flat node_modules/ without
#             pnpm's `.pnpm` virtual store, saving ~100 MB.
#   runtime — production deps + compiled output, non-root user, no
#             prisma CLI installed.
#
# Why npm in Docker (not pnpm):
#   pnpm's `pnpm prune --prod` removes devDep entries from package.json
#   but leaves the .pnpm virtual store on disk. The runtime stage
#   copying node_modules/ would drag in 100+ MB of devDep transitives
#   (eslint, vitest, tsc, tsx, openapi-types, typescript, prisma CLI).
#   Switching the DOCKER build to npm (the dev workflow still uses
#   pnpm via `packageManager` in package.json) is the lowest-friction
#   way to get a flat prod-only node_modules.
#
# Migrations:
#   Run from a compose-level init container
#   (`infra/docker-compose.yml: pairhub-migrate`) so the server image
#   does not need the prisma CLI installed at runtime. To run
#   migrations out-of-band: `docker run --rm --network pairhub_pairhub \
#   <image> npx prisma migrate deploy`.
# =====================================================================

# ---- 1. build ----
FROM node:20-alpine AS build
WORKDIR /app

RUN apk add --no-cache libc6-compat openssl

# Install ALL deps (dev + prod) with npm so we can run prisma generate
# + tsc. The dev workflow uses pnpm (see packageManager in package.json)
# but the docker build uses npm for a flat prod-only tree in the runtime
# stage.
COPY package.json package-lock.json* ./
RUN npm install --no-audit --no-fund

COPY . .
RUN npx prisma generate \
 && npm run build

# ---- 2. runtime ----
FROM node:20-alpine AS runtime
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOST=0.0.0.0

# Runtime libs: libc6-compat (for Prisma engine), openssl (for sentry),
# tini (PID 1 to forward SIGTERM).
RUN apk add --no-cache libc6-compat openssl tini

# Run as non-root.
RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001

# `npm ci --omit=dev` (only when a package-lock.json is present)
# produces a flat prod-only node_modules/ — no pnpm virtual store.
# The lockfile is generated by `npm install --package-lock-only` in
# the build stage if it isn't checked in (the source repo currently
# only ships pnpm-lock.yaml; the build stage adds a transient
# package-lock.json that gets baked into the image but never written
# to the source tree).
COPY package.json ./
RUN if [ -f package-lock.json ]; then \
      echo "package-lock.json present" && npm ci --omit=dev --no-audit --no-fund; \
    else \
      echo "no package-lock.json — running npm install --omit=dev"; \
      npm install --omit=dev --no-audit --no-fund --no-package-lock; \
    fi

# Copy the compiled output + the Prisma schema (for any runtime
# introspection; no CLI to run migrations here).
COPY --from=build --chown=nodejs:nodejs /app/dist ./dist
COPY --from=build --chown=nodejs:nodejs /app/prisma ./prisma

USER nodejs
EXPOSE 3000

# tini = proper PID 1, forwards SIGTERM to node for graceful shutdown.
ENTRYPOINT ["/sbin/tini", "--"]

# See header for the migrations story.
CMD ["node", "dist/server.js"]
